---
import '../styles/global.css';

const baseUrl = import.meta.env.BASE_URL;

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Anand Writes</title>
	</head>
	<body class="mx-auto max-w-3xl px-6 py-12 text-zinc-900">
		<main>
			<h1 class="text-4xl font-bold">Anand Writes</h1>
			<p class="mt-3 text-zinc-600">Engineering notes on protocols, architecture, and web systems.</p>
			<p class="mt-8">
				<a href={`${baseUrl}blog/`} class="rounded-md border border-zinc-300 px-4 py-2 hover:border-zinc-500">Read the blog</a>
			</p>
		</main>
	</body>
</html>
